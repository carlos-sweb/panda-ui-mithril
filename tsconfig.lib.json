{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "panda-ui/*": ["./styled-system/*"]
    },
    "types": [],
  },
  "include": ["src/**/*", "styled-system/**/*"],
  "exclude": ["node_modules", "dist", "playground"]
}
